# .kamal/secrets — Kamal 2 secrets template
#
# COPY THIS FILE to .kamal/secrets, fill in real values, and NEVER commit .kamal/secrets.
# Add to .gitignore:
#   .kamal/secrets*
#   !.kamal/secrets.example
#
# Format: KEY=value (dotenv, supports shell substitution and command execution)
# All values are encrypted and transmitted over SSH — never logged or visible in docker inspect.
# =============================================================================

# ---- REGISTRY ---------------------------------------------------------------
# Required: used by registry.password in config/deploy.yml

# Docker Hub token (create at https://hub.docker.com/settings/security)
KAMAL_REGISTRY_PASSWORD=your-docker-hub-token

# GHCR (GitHub Container Registry) — use a PAT with write:packages scope
# KAMAL_REGISTRY_PASSWORD=ghp_your_github_personal_access_token

# AWS ECR — use ERB in deploy.yml instead (tokens expire every 12h):
# registry:
#   password: <%= `aws ecr get-login-password --region us-east-1` %>

# ---- APP SECRETS ------------------------------------------------------------

# Database password
DATABASE_PASSWORD=your-database-password

# Session / cookie secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your-session-secret-here

# API keys
# API_KEY=your-api-key
# S3_SECRET_KEY=your-s3-secret

# ---- SHELL SUBSTITUTION EXAMPLES -------------------------------------------
# Reference other environment variables:
# KAMAL_REGISTRY_PASSWORD=$GITHUB_TOKEN

# Read from a file:
# APP_SECRET=$(cat /path/to/secret.key)

# Fetch from AWS Secrets Manager:
# DATABASE_PASSWORD=$(aws secretsmanager get-secret-value \
#   --secret-id prod/myapp/db \
#   --query SecretString \
#   --output text)

# Fetch from HashiCorp Vault:
# DATABASE_PASSWORD=$(vault kv get -field=password secret/myapp/db)

# Fetch from Google Secret Manager:
# DATABASE_PASSWORD=$(gcloud secrets versions access latest --secret="myapp-db-password")

# Fetch from 1Password (batch fetch for efficiency):
# SECRETS=$(kamal secrets fetch --adapter 1password --account myaccount --from "Kamal/production")
# DATABASE_PASSWORD=$(kamal secrets extract DATABASE_PASSWORD $SECRETS)
# SESSION_SECRET=$(kamal secrets extract SESSION_SECRET $SECRETS)
# KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD $SECRETS)

# ---- SSL (optional) ---------------------------------------------------------
# Only needed if using custom TLS certificates (not needed for auto Let's Encrypt)
# SSL_CERTIFICATE_PEM=$(cat /path/to/certificate.pem)
# SSL_PRIVATE_KEY_PEM=$(cat /path/to/private-key.pem)
